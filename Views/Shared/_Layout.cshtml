@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action     = ViewContext.RouteData.Values["action"]?.ToString();
    var isHome     = controller == "Home" && action == "Index";
    var isAdmin    = controller == "Admin";
    var isUser     = controller == "User";
    var isDashboard = isAdmin && action == "Dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NextInLine</title>

    <!-- Fuentes + iconos primero -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    @if (isHome)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    }

    <!-- Materialize ANTES de nuestros estilos para que podamos pisarlos -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet" />

    <!-- Nuestro design system (sobreescribe Materialize) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />

    @if (isHome)
    {
        <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    }
    else if (isAdmin)
    {
        <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    }
    else if (isUser)
    {
        <link rel="stylesheet" href="~/css/user.css" asp-append-version="true" />
    }

    @await RenderSectionAsync("Head", required: false)
</head>

<body>

<!-- ══════════════ NAVBAR ══════════════ -->
<header>
@if (isHome)
{
    <nav class="nil-navbar nil-navbar--light">
        <a class="nil-navbar__brand" asp-controller="Home" asp-action="Index">
            Next<span>InLine</span>
        </a>
        <div class="nil-navbar__right">
            <div class="nil-navbar__links">
                <a class="nil-navbar__link" href="#features">Features</a>
                <a class="nil-navbar__link" href="#">About</a>
            </div>
            <a asp-action="Turn" asp-controller="User"
               class="btn-primary-hero"
               style="padding:9px 20px; font-size:13px; border-radius:20px; box-shadow:none;">
                Get your turn
            </a>
        </div>
    </nav>
}
else if (isAdmin)
{
    <nav class="nil-navbar">
        <div style="display:flex; align-items:center;">
            <a class="nil-navbar__brand" asp-controller="Home" asp-action="Index">
                Next<span>InLine</span>
            </a>
            <span class="nil-navbar__section">/ Admin</span>
        </div>
        <div class="nil-navbar__right">
            <div class="nil-navbar__links">
                <a class="nil-navbar__link @(action == "Dashboard" ? "active" : "")"
                   asp-action="Dashboard" asp-controller="Admin">Dashboard</a>
                <a class="nil-navbar__link @(action == "Index" ? "active" : "")"
                   asp-action="Index" asp-controller="Admin">Cola</a>
            </div>
            <div class="nil-chip nil-chip--mono" id="adminClock">--:--:--</div>
        </div>
    </nav>
}
else if (isUser)
{
    <nav class="nil-navbar">
        <a class="nil-navbar__brand" asp-controller="Home" asp-action="Index">
            Next<span>InLine</span>
        </a>
        <div class="nil-navbar__right">
            @if (action == "Index")
            {
                <div class="nil-chip" id="waitingBadge">
                    <div class="nil-chip__dot"></div>
                    <span id="waitingCount">0</span>&nbsp;en espera
                </div>
                <div class="nil-chip nil-chip--mono" id="userClock">--:--:--</div>
                <span style="font-size:11px; color:var(--nil-blue-dim);">Medellín</span>
            }
        </div>
    </nav>
}
else
{
    <nav class="nil-navbar">
        <a class="nil-navbar__brand" asp-controller="Home" asp-action="Index">
            Next<span>InLine</span>
        </a>
        <div class="nil-navbar__right">
            <a class="nil-navbar__link" asp-controller="Home" asp-action="Index">Home</a>
        </div>
    </nav>
}

<!-- Sidenav móvil -->
<ul class="sidenav" id="mobile-menu">
    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
    <li><a asp-action="Turn" asp-controller="User">Get your turn</a></li>
    @if (isAdmin)
    {
        <li><a asp-action="Dashboard" asp-controller="Admin">Dashboard</a></li>
        <li><a asp-action="Index" asp-controller="Admin">Cola</a></li>
    }
</ul>
</header>

<!-- ══════════════ CONTENIDO ══════════════ -->
<main>
    @RenderBody()
</main>

<!-- ══════════════ FOOTER (solo fuera de admin/user app) ══════════════ -->
@if (!isAdmin && !isUser)
{
    <footer class="nil-footer">
        <div class="nil-footer__inner">
            <div>
                <span class="nil-footer__brand">Next<span>InLine</span></span>
                <p class="nil-footer__desc">
                    Smart queue management for clinics, banks,
                    retail stores and modern service businesses.
                </p>
            </div>
            <div>
                <p class="nil-footer__heading">Quick Links</p>
                <ul class="nil-footer__list">
                    <li><a href="#">Home</a></li>
                    <li><a href="#features">Features</a></li>
                    <li><a asp-action="Turn" asp-controller="User">Get a turn</a></li>
                </ul>
            </div>
            <div>
                <p class="nil-footer__heading">Contact</p>
                <p class="nil-footer__contact-line">support@nextinline.com</p>
                <p class="nil-footer__contact-line">Medellín, Colombia</p>
            </div>
        </div>
        <div class="nil-footer__bottom" style="max-width:1280px; width:100%;">
            <span class="nil-footer__copy">© 2026 NextInLine. All rights reserved.</span>
            <span class="nil-footer__copy">Built for better customer experiences.</span>
        </div>
    </footer>
}

<!-- ══════════════ SCRIPTS ══════════════ -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var elems = document.querySelectorAll('.sidenav');
        M.Sidenav.init(elems);
    });

    // Reloj Colombia (disponible para admin y user)
    function nilClock(elemId) {
        const el = document.getElementById(elemId);
        if (!el) return;
        function tick() {
            const col = new Date(new Date().toLocaleString("en-US", { timeZone: "America/Bogota" }));
            const p = n => String(n).padStart(2, "0");
            el.textContent = `${p(col.getHours())}:${p(col.getMinutes())}:${p(col.getSeconds())}`;
        }
        tick();
        setInterval(tick, 1000);
    }
    nilClock('adminClock');
    nilClock('userClock');
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
