@{
    ViewData["Title"] = "NextInLine — Smart Queue Management";
}

<!-- ══════════════ HERO ══════════════ -->
<section class="hero">
    <div class="hero__inner">
        <div class="hero__eyebrow">Queue Management Platform</div>

        <h1 class="hero__title">
            Atiende a tus clientes<br>
            sin <em>filas</em>, sin caos.
        </h1>

        <p class="hero__desc">
            NextInLine es un sistema de turnos digital para clínicas, bancos,
            tiendas y oficinas. Crea filas virtuales, llama clientes en orden
            y gestiona tu sala de espera en tiempo real.
        </p>

        <div class="hero__actions">
            <a asp-controller="User" asp-action="Turn" class="btn-primary-hero">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                </svg>
                Obtener turno ahora
            </a>
            <a href="#features" class="btn-secondary-hero">
                Ver características
            </a>
        </div>

        <div class="hero__stats">
            <div class="hero__stat">
                <span class="hero__stat-value">−62%</span>
                <span class="hero__stat-label">Tiempo de espera promedio</span>
            </div>
            <div class="hero__stat">
                <span class="hero__stat-value">+38%</span>
                <span class="hero__stat-label">Satisfacción del cliente (NPS)</span>
            </div>
            <div class="hero__stat">
                <span class="hero__stat-value">0</span>
                <span class="hero__stat-label">Tickets en papel</span>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════ FEATURES ══════════════ -->
<section class="features" id="features">
    <div class="section-inner">
        <span class="section-eyebrow">Características</span>
        <h2 class="section-title">
            Todo lo que necesitas para que<br>
            las filas <em>simplemente funcionen.</em>
        </h2>

        <div class="features-grid">

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-clipboard2-check-fill"></i>
                </div>
                <div class="feature-title">Registro inteligente</div>
                <p class="feature-desc">
                    Crea tickets en segundos validando el documento.
                    Si el usuario ya existe, el sistema lo reconoce automáticamente.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-display"></i>
                </div>
                <div class="feature-title">Sala de espera en vivo</div>
                <p class="feature-desc">
                    Pantalla con el turno actual, estado de la cola en tiempo real
                    y contenido visual mientras se espera.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-headset"></i>
                </div>
                <div class="feature-title">Panel del asesor</div>
                <p class="feature-desc">
                    Llama el siguiente turno y actualiza datos del cliente
                    desde un dashboard único y sencillo.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-volume-up-fill"></i>
                </div>
                <div class="feature-title">Llamada por sonido</div>
                <p class="feature-desc">
                    Alertas sonoras y notificaciones automáticas cuando
                    el turno del cliente es llamado.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-bar-chart-fill"></i>
                </div>
                <div class="feature-title">Métricas claras</div>
                <p class="feature-desc">
                    Tiempo promedio de atención, rendimiento por asesor
                    y estadísticas de demanda en tiempo real.
                </p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <div class="feature-title">Tiempo real con SignalR</div>
                <p class="feature-desc">
                    Actualización instantánea de la cola sin recargar la página,
                    para asesores y clientes simultáneamente.
                </p>
            </div>

        </div>
    </div>
</section>

<!-- ══════════════ CTA ══════════════ -->
<section class="cta-section">
    <div class="cta-section__inner">
        <h2 class="cta-section__title">¿Listo para eliminar las filas?</h2>
        <p class="cta-section__desc">
            Únete a la cola digital ahora mismo. Sin instalaciones, sin papel,
            sin esperas innecesarias.
        </p>
        <a asp-controller="User" asp-action="Turn" class="btn-cta">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
            </svg>
            Obtener mi turno
        </a>
    </div>
</section>
