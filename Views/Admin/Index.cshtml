@using NextInLine.Enums
@model IEnumerable<Ticket>
@{
    ViewData["Title"] = "Cola de turnos";

    int pendings = Model
        .Where(t => t.Status == TicketStatus.pending && t.CreatedAt.Date == DateTime.UtcNow.Date)
        .Count();

    int servedToday = Model
        .Where(t => t.Status == TicketStatus.closed && t.CreatedAt.Date == DateTime.UtcNow.Date)
        .Count();

    var waitTimes = Model
        .Where(t => t.Status == TicketStatus.pending && t.CreatedAt.Date == DateTime.UtcNow.Date)
        .Select(t => (DateTime.UtcNow - t.CreatedAt).TotalMinutes)
        .ToList();

    var avgTime = TimeSpan.FromMinutes(waitTimes.Any() ? waitTimes.Average() : 0);

    var currentOpen = Model
        .Where(t => t.Status == TicketStatus.open && t.CreatedAt.Date == DateTime.UtcNow.Date)
        .OrderByDescending(t => t.CreatedAt)
        .FirstOrDefault();
}

<div id="toast" class="nil-toast"></div>

<div class="nil-page">
    <div class="admin-grid">

        <!-- ── Columna izquierda: turno actual + botón ── -->
        <div>
            <div class="nil-card">
                <div class="turn-display">
                    <div class="turn-label">Turno en curso</div>
                    <div class="turn-code" id="currentTurn">@(currentOpen?.Code ?? "—")</div>
                    <div class="turn-sub">Atendiendo ahora</div>
                </div>
                <div class="nil-btn-next-wrap">
                    <form id="antiForgeryForm">
                        @Html.AntiForgeryToken()
                        <button id="nextTurnBtn" class="nil-btn-next" type="button">
                            <div class="nil-btn-next__inner">
                                <div class="btn-arrow">
                                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
                                        <path d="M2 5.5H9M9 5.5L6 2.5M9 5.5L6 8.5"
                                              stroke="white" stroke-width="1.5"
                                              stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </div>
                                Llamar siguiente turno
                            </div>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- ── Columna derecha: stats + tabla ── -->
        <div>
            <div class="stat-grid">
                <div class="stat-card">
                    <div class="stat-label">En espera</div>
                    <div class="stat-value" id="pendingsToday">@pendings</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Atendidos hoy</div>
                    <div class="stat-value stat-value--green">@servedToday</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Espera promedio</div>
                    <div class="stat-value stat-value--amber nil-mono">
                        @($"{avgTime.Hours:D2}:{avgTime.Minutes:D2}")
                    </div>
                </div>
            </div>

            <div class="nil-card">
                <div class="nil-card__header">Cola de tickets</div>
                <div class="nil-table-wrap">
                    <table class="nil-table">
                        <thead>
                            <tr>
                                <th>Ticket</th>
                                <th>Estado</th>
                                <th>Tiempo en espera</th>
                            </tr>
                        </thead>
                        <tbody id="ticketsTbody"></tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/turnHub")
        .withAutomaticReconnect()
        .build();

    const toast       = document.getElementById("toast");
    const btnNext     = document.getElementById("nextTurnBtn");
    const statPending = document.getElementById("pendingsToday");
    const token       = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]').value;

    let cachedTickets = [];

    function timerClass(ms) {
        const m = Math.floor(ms / 60000);
        return m < 5 ? "timer-ok" : m < 15 ? "timer-warn" : "timer-hot";
    }

    function renderTable() {
        const tbody = document.getElementById("ticketsTbody");
        if (!cachedTickets.length) {
            tbody.innerHTML = `<tr><td colspan="3" style="text-align:center;color:var(--nil-slate);padding:28px;font-size:13px;">Sin tickets en espera</td></tr>`;
            return;
        }
        tbody.innerHTML = cachedTickets.map(t => {
            const ms  = Date.now() - new Date(t.createdAt).getTime();
            const sec = Math.floor(ms / 1000);
            const min = Math.floor(sec / 60);
            const fmt = `${String(min).padStart(2,"0")}:${String(sec % 60).padStart(2,"0")}`;
            return `
                <tr>
                    <td class="nil-mono">${t.code}</td>
                    <td><span class="status-pill pill-pending">Pending</span></td>
                    <td><span class="timer-chip ${timerClass(ms)}">${fmt}</span></td>
                </tr>`;
        }).join("");
    }

    async function refreshTickets() {
        const res = await fetch("/Admin/GetTicketsPendings");
        cachedTickets = await res.json();
        statPending.textContent = cachedTickets.length;
        renderTable();
    }

    refreshTickets();
    setInterval(refreshTickets, 30000);
    setInterval(renderTable, 1000);

    btnNext.addEventListener("click", async () => {
        btnNext.disabled = true;
        try {
            const res  = await fetch("/Admin/NextTurn", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": token
                }
            });
            const code = await res.text();
            document.getElementById("currentTurn").textContent = code !== "NO_TICKETS" ? code : "—";
            await refreshTickets();
        } catch (err) {
            console.error("Error NextTurn:", err);
        } finally {
            btnNext.disabled = false;
        }
    });

    connection.on("ReceiveTurn", (code) => {
        toast.textContent = `Nuevo turno: ${code}`;
        toast.style.display = "block";
        setTimeout(() => { toast.style.display = "none"; refreshTickets(); }, 3000);
    });

    connection.start().catch(err => console.error("SignalR error:", err));
</script>
}
