@using NextInLine.Enums
@model IEnumerable<Ticket> 
@{
    ViewData["message"] = "Mensaje";
    int pendings = @Model.Where(t => t.Status == TicketStatus.pending).Where(t => t.CreatedAt.Date == DateTime.UtcNow.Date).Count();
    var tickets = @Model.Where(t => t.Status == TicketStatus.pending).Where(t => t.CreatedAt.Date == DateTime.UtcNow.Date);
    
    int servedToday = @Model.Where(t => t.Status == TicketStatus.closed).Where(t => t.CreatedAt.Date == DateTime.UtcNow.Date).Count();
    var pendingsTotal = @Model.Where(t => t.Status == TicketStatus.pending)
        .Where(t => t.CreatedAt.Date == DateTime.UtcNow.Date)
        .Select(t => t.CreatedAt)
        .ToList();
    var averageMinutes = pendingsTotal
        .Select(date => (DateTime.UtcNow - date).TotalMinutes)
        .DefaultIfEmpty(0)
        .Average();
    
    var averageTime = TimeSpan.FromMinutes(averageMinutes);
}

<div>
    <div class="container" style="padding-top:35px;">

        <!-- HEADER -->
        <div class="row valign-wrapper">
            <div class="col s12 m6">
                <h4 class="grey-text text-darken-4" style="margin:0;">
                    Panel de control de Tickets
                </h4>
                <p class="grey-text">Nota: La pasciencia es una virtud</p>
            </div>
        </div>

        <!-- MAIN GRID -->
        <div class="row">

            <!-- LEFT SIDE -->
            <div class="col s12 l4">

                <!-- CURRENT TURN -->
                <div class="card white z-depth-1" style="border-radius:18px;">
                    <div class="card-content center-align">
                        <p class="grey-text">CURRENT TURN</p>
                        <h1 class="teal-text text-darken-2" style="margin:0; font-size:5rem;">A17</h1>
                        <p class="grey-text">Serving now</p>
                    </div>
                </div>

                <!-- QUICK ACTIONS -->
                <div class="card white z-depth-1" style="border-radius:18px;">
                    <div class="card-content">

                        <h6><b>Quick Actions</b></h6>

                        <a class="btn-large teal darken-1 waves-effect waves-light"
                           style="width:100%; border-radius:30px; margin-top:15px;">
                            <i class="material-icons left">skip_next</i>
                            Next Turn
                        </a>

                        <a class="btn-large orange waves-effect waves-light"
                           style="width:100%; border-radius:30px; margin-top:15px;">
                            <i class="material-icons left">free_breakfast</i>
                            Break Mode
                        </a>

                        <a class="btn-large red waves-effect waves-light"
                           style="width:100%; border-radius:30px; margin-top:15px;">
                            <i class="material-icons left">cancel</i>
                            Cancel Turn
                        </a>

                    </div>
                </div>

            </div>

            <!-- CENTER -->
            <div class="col s12 l8">

                <!-- LIVE STATS -->
                <div class="row">

                    <div class="col s12 m4">
                        <div class="card white z-depth-1 center-align" style="border-radius:18px;">
                            <div class="card-content">
                                <h4 class="teal-text">@pendings</h4>
                                <p class="grey-text">Waiting</p>
                            </div>
                        </div>
                    </div>

                    <div class="col s12 m4">
                        <div class="card white z-depth-1 center-align" style="border-radius:18px;">
                            <div class="card-content">
                                <h4 class="teal-text">@($"{averageTime.Hours}h {averageTime.Minutes}m")</h4>
                                <p class="grey-text">Avg Wait</p>
                            </div>
                        </div>
                    </div>

                    <div class="col s12 m4">
                        <div class="card white z-depth-1 center-align" style="border-radius:18px;">
                            <div class="card-content">
                                <h4 class="teal-text">@servedToday</h4>
                                <p class="grey-text">Served Today</p>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- TURN TABLE -->
                <div class="card white z-depth-1" style="border-radius:18px;">
                    <div class="card-content">

                        <div class="row valign-wrapper" style="margin-bottom:0;">
                            <div class="col s12 m6">
                                <h5 class="grey-text text-darken-4">All Tickets</h5>
                            </div>
                        </div>

                        <table class="highlight responsive-table striped centered">
                            <thead>
                                <tr>
                                    <th>Ticket</th>
                                    <th>Status</th>
                                    <th>Tiempo de espera</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var ticket in tickets)
                                {
                                    
                                    TimeSpan waitingTime = DateTime.UtcNow - ticket.CreatedAt;
                                    
                                    <tr>
                                        <td>@ticket.Code</td>
                                        <td>
                                            <span class="chip orange white-text" data-badge-caption="">@ticket.Status</span>
                                        </td>
                                        <td> @($"{waitingTime.Minutes:D2}:{waitingTime.Seconds:D2}")</td>
                                    </tr>
                                }

                            </tbody>
                        </table>

                    </div>
                </div>

            </div>

        </div>

    </div>

</div>
