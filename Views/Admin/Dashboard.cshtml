                            <div class="col s12 m6">
                                <h5 class="grey-text text-darken-4">
                                    Registered Users
                                </h5>
                            </div>

                            <div class="col s12 m6 right-align">
                                <input type="text"
                                       placeholder="Search user..."
                                       style="border:1px solid #ddd; padding-left:15px; border-radius:10px;">
                            </div>

                        </div>

                        <table class="highlight responsive-table">

                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Status</th>
                                    <th>Turns</th>
                                </tr>
                            </thead>

                            <tbody>

                                <tr>
                                    <td>John Carter</td>
                                    <td>john@email.com</td>
                                    <td><span class="new badge green" data-badge-caption="">Active</span></td>
                                    <td>12</td>
                                </tr>

                                <tr>
                                    <td>Emma Smith</td>
                                    <td>emma@email.com</td>
                                    <td><span class="new badge blue" data-badge-caption="">Waiting</span></td>
                                    <td>6</td>
