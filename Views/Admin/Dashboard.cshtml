@model NextInLine.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="nil-page">

    <!-- Header -->
    <div class="dash-header">
        <h1 class="dash-header__title">Dashboard</h1>
        <p class="dash-header__sub">Resumen de actividad del día de hoy.</p>
    </div>

    <!-- Métricas -->
    <div class="dash-metric-grid">

        <div class="dash-metric">
            <div class="dash-metric__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nil-blue)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
            </div>
            <div>
                <div class="dash-metric__value">@Model.TotalUsersCount</div>
                <div class="dash-metric__label">Usuarios únicos</div>
            </div>
        </div>

        <div class="dash-metric">
            <div class="dash-metric__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nil-blue)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <path d="M8 21h8M12 17v4"/>
                </svg>
            </div>
            <div>
                <div class="dash-metric__value">@Model.TicketsToday</div>
                <div class="dash-metric__label">Tickets hoy</div>
            </div>
        </div>

        <div class="dash-metric">
            <div class="dash-metric__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nil-green)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                </svg>
            </div>
            <div>
                <div class="dash-metric__value" style="color:var(--nil-green);">@Model.CompletedToday</div>
                <div class="dash-metric__label">Completados hoy</div>
            </div>
        </div>

        <div class="dash-metric">
            <div class="dash-metric__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nil-amber)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                </svg>
            </div>
            <div>
                <div class="dash-metric__value" style="color:var(--nil-amber);font-size:22px;">@Model.AvgWaitTime</div>
                <div class="dash-metric__label">Espera promedio</div>
            </div>
        </div>

    </div>

    <!-- Tabla de usuarios activos de hoy -->
    <div class="nil-card">
        <div class="dash-table-header">
            <h5>Actividad de hoy</h5>
            <a asp-action="Index" asp-controller="Admin"
               style="font-size:12px; color:var(--nil-blue-mid); text-decoration:none; font-weight:500;">
                Ir a cola →
            </a>
        </div>
        <div class="nil-table-wrap">
            <table class="nil-table">
                <thead>
                    <tr>
                        <th>Ticket</th>
                        <th>Estado</th>
                        <th>Creado</th>
                    </tr>
                </thead>
                <tbody id="dashTbody">
                    <tr>
                        <td colspan="3" style="text-align:center;color:var(--nil-slate);padding:28px;font-size:13px;">
                            Cargando...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
<script>
    async function loadDashTable() {
        const res = await fetch("/Admin/GetTicketsPendings");
        const tickets = await res.json();
        const tbody = document.getElementById("dashTbody");

        if (!tickets.length) {
            tbody.innerHTML = `<tr><td colspan="3" style="text-align:center;color:var(--nil-slate);padding:28px;font-size:13px;">Sin tickets en espera ahora mismo</td></tr>`;
            return;
        }

        tbody.innerHTML = tickets.map(t => {
            const d   = new Date(t.createdAt);
            const pad = n => String(n).padStart(2,"0");
            const time = `${pad(d.getHours())}:${pad(d.getMinutes())}`;
            return `
                <tr>
                    <td class="nil-mono">${t.code}</td>
                    <td><span class="status-pill pill-pending">Pending</span></td>
                    <td style="font-size:12px;color:var(--nil-slate);font-family:var(--font-mono);">${time}</td>
                </tr>`;
        }).join("");
    }

    loadDashTable();
</script>
}
