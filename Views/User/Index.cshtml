@using NextInLine.Enums
@model IEnumerable<Ticket>
@{
    var tickets = Model
        .Where(t => t.Status == TicketStatus.pending)
        .Where(t => t.CreatedAt.Date == DateTime.UtcNow.Date)
        .OrderBy(t => t.CreatedAt)
        .ToList();

    var currentTurn = Model
        .Where(t => t.Status == TicketStatus.closed)
        .Where(t => t.CreatedAt.Date == DateTime.UtcNow.Date)
        .OrderByDescending(t => t.CreatedAt)
        .FirstOrDefault();
}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: 'DM Sans', sans-serif;
        background: #eef2f8;
        min-height: 100vh;
    }

    /* NAV */
    .nil-nav {
        background: #0c1f3a;
        padding: 0 32px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 100;
    }
    .nil-brand {
        font-family: 'DM Mono', monospace;
        font-size: 15px;
        font-weight: 500;
        color: #b5d4f4;
        letter-spacing: 0.04em;
        text-decoration: none;
    }
    .nil-brand span { color: #378ADD; }
    .nil-nav-right {
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .nil-clock {
        font-family: 'DM Mono', monospace;
        font-size: 13px;
        color: #85b7eb;
        background: #0d2444;
        padding: 5px 14px;
        border-radius: 6px;
        letter-spacing: 0.03em;
    }
    .nil-waiting-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #0d2444;
        color: #85b7eb;
        font-size: 12px;
        font-weight: 500;
        padding: 5px 14px;
        border-radius: 6px;
    }
    .badge-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #378ADD;
        flex-shrink: 0;
    }

    /* LAYOUT */
    .nil-page {
        padding: 28px 32px;
        max-width: 1280px;
        margin: 0 auto;
    }
    .nil-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 20px;
        align-items: start;
    }

    /* CARDS */
    .nil-card {
        background: #ffffff;
        border-radius: 14px;
        border: 0.5px solid #d1dae8;
        overflow: hidden;
        margin-bottom: 16px;
    }
    .nil-card:last-child { margin-bottom: 0; }
    .nil-card-header {
        padding: 13px 20px;
        border-bottom: 0.5px solid #e8edf5;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: #6b8aad;
    }
    .nil-card-body { padding: 20px; }

    /* TURNO ACTUAL */
    .turn-display {
        text-align: center;
        padding: 32px 20px 28px;
    }
    .turn-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #6b8aad;
        margin-bottom: 14px;
    }
    .turn-code {
        font-family: 'DM Mono', monospace;
        font-size: 56px;
        font-weight: 500;
        color: #0c1f3a;
        line-height: 1;
        margin-bottom: 8px;
        transition: all 0.3s ease;
    }
    .turn-sub {
        font-size: 12px;
        color: #6b8aad;
    }

    /* QUEUE LIST */
    .queue-list { list-style: none; }
    .queue-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 11px 20px;
        border-bottom: 0.5px solid #edf1f7;
        transition: background 0.1s;
    }
    .queue-item:last-child { border-bottom: none; }
    .queue-item:hover { background: #f8fafd; }
    .queue-code {
        font-family: 'DM Mono', monospace;
        font-weight: 500;
        font-size: 13px;
        color: #0c1f3a;
    }
    .queue-time {
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: #6b8aad;
        background: #eef2f8;
        padding: 3px 9px;
        border-radius: 4px;
    }
    .queue-empty {
        padding: 20px;
        text-align: center;
        font-size: 13px;
        color: #6b8aad;
    }

    /* VIDEO */
    .nil-video {
        width: 100%;
        border-radius: 10px;
        display: block;
    }
    .video-caption {
        font-size: 12px;
        color: #6b8aad;
        text-align: center;
        margin-top: 14px;
    }

    /* TOAST */
    .nil-toast {
        position: fixed;
        top: 72px;
        right: 24px;
        background: #0c1f3a;
        color: #b5d4f4;
        padding: 13px 20px;
        border-radius: 10px;
        border: 0.5px solid #1e3a5c;
        display: none;
        z-index: 9999;
        font-size: 13px;
        font-weight: 500;
        font-family: 'DM Mono', monospace;
        letter-spacing: 0.03em;
    }
</style>

<div id="toast" class="nil-toast"></div>

<!-- NAV -->
<nav class="nil-nav">
    <a class="nil-brand" href="/">Next<span>InLine</span></a>
    <div class="nil-nav-right">
        <div class="nil-waiting-badge">
            <div class="badge-dot"></div>
            <span id="waitingCount">@tickets.Count</span> en espera
        </div>
        <div class="nil-clock" id="userClock">--:--:--</div>
        <span style="font-size:11px; color:#4a6a8a;">Medellín</span>
    </div>
</nav>

<!-- PAGE -->
<div class="nil-page">
    <div class="nil-grid">

        <!-- LEFT — turno actual + próximos -->
        <div>
            <div class="nil-card">
                <div class="turn-display">
                    <div class="turn-label">Turno actual</div>
                    <div class="turn-code" id="currentTurn">@(currentTurn?.Code ?? "—")</div>
                    <div class="turn-sub">Atendiendo ahora</div>
                </div>
            </div>

            <div class="nil-card">
                <div class="nil-card-header">Próximos en fila</div>
                <ul class="queue-list" id="nextInLine">
                    @if (!tickets.Any())
                    {
                        <li class="queue-empty">Sin tickets en espera</li>
                    }
                    else
                    {
                        @foreach (var ticket in tickets.Take(10))
                        {
                            var h = ticket.CreatedAt.ToString("HH");
                            var m = ticket.CreatedAt.ToString("mm");
                            <li class="queue-item">
                                <span class="queue-code">@ticket.Code</span>
                                <span class="queue-time">@h:@m</span>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>

        <!-- RIGHT — video -->
        <div class="nil-card">
            <div class="nil-card-header">Sala de espera</div>
            <div class="nil-card-body">
                <video class="nil-video"
                       src="/files/waitingroom.mp4"
                       autoplay loop muted playsinline>
                    Tu navegador no soporta la reproducción de video.
                </video>
                <p class="video-caption">Mientras esperas, disfruta del contenido.</p>
            </div>
        </div>

    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
<script>
    // ── SignalR ──
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/turnHub")
        .withAutomaticReconnect()
        .build();

    const toast = document.getElementById("toast");

    // ── Reloj Colombia ──
    function tickClock() {
        const col = new Date(new Date().toLocaleString("en-US", { timeZone: "America/Bogota" }));
        const pad = n => String(n).padStart(2, "0");
        document.getElementById("userClock").textContent =
            `${pad(col.getHours())}:${pad(col.getMinutes())}:${pad(col.getSeconds())}`;
    }
    tickClock();
    setInterval(tickClock, 1000);

    // ── Actualizar lista de tickets ──
    async function refreshTickets(incomingCode = null) {
        const res     = await fetch("/Admin/GetTicketsPendings");
        const tickets = await res.json();

        document.getElementById("waitingCount").textContent = tickets.length;

        const list = document.getElementById("nextInLine");
        if (!tickets.length) {
            list.innerHTML = `<li class="queue-empty">Sin tickets en espera</li>`;
        } else {
            list.innerHTML = tickets.slice(0, 10).map(t => {
                const d   = new Date(t.createdAt);
                const pad = n => String(n).padStart(2, "0");
                return `
                    <li class="queue-item">
                        <span class="queue-code">${t.code}</span>
                        <span class="queue-time">${pad(d.getHours())}:${pad(d.getMinutes())}</span>
                    </li>`;
            }).join("");
        }

        if (incomingCode) {
            const isPending = tickets.some(t => t.code === incomingCode);
            if (!isPending && incomingCode !== "NO_TICKETS") {
                // Sonido
                const ctx        = new AudioContext();
                const oscillator = ctx.createOscillator();
                const gainNode   = ctx.createGain();
                oscillator.connect(gainNode);
                gainNode.connect(ctx.destination);
                oscillator.type = "sine";
                oscillator.frequency.setValueAtTime(880, ctx.currentTime);
                oscillator.frequency.setValueAtTime(660, ctx.currentTime + 0.1);
                gainNode.gain.setValueAtTime(0.5, ctx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.5);
                oscillator.start(ctx.currentTime);
                oscillator.stop(ctx.currentTime + 0.5);

                // Actualizar turno en pantalla
                document.getElementById("currentTurn").textContent = incomingCode;
                toast.textContent = `Turno llamado: ${incomingCode}`;
                toast.style.display = "block";
                setTimeout(() => toast.style.display = "none", 3000);
            }
        }
    }

    connection.on("ReceiveTurn", (code) => refreshTickets(code));
    connection.start().then(() => console.log("SignalR Usuario conectado"));

    refreshTickets();
</script>
