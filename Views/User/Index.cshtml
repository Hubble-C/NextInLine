@using NextInLine.Enums
@model IEnumerable<Ticket>
@{
    var tickets = Model
        .Where(t => t.Status == TicketStatus.pending)
        .Where(t => t.CreatedAt.Date == DateTime.UtcNow.Date)
        .OrderBy(t => t.CreatedAt)
        .ToList();

    var currentTurn = Model
        .Where(t => t.Status == TicketStatus.closed)
        .Where(t => t.CreatedAt.Date == DateTime.UtcNow.Date)
        .OrderByDescending(t => t.CreatedAt)
        .FirstOrDefault();
}

<div class="container-fluid teal lighten-5" style="min-height:100vh; padding:40px;">

    <!-- TOP BAR -->
    <div class="row valign-wrapper" style="margin-bottom:30px;">
        <div class="col s12 m6">
            <h4 class="grey-text text-darken-4" style="margin:0;">
                <b>Fila</b> Queue System
            </h4>
            <p class="grey-text">Welcome. Please wait for your turn.</p>
        </div>
        <div class="col s12 m6 right-align">
            <span class="chip white z-depth-1">
                <i class="material-icons tiny">schedule</i>
                Waiting: <span id="waitingCount">@tickets.Count</span>
            </span>
        </div>
    </div>

    <div class="row">

        <!-- LEFT SIDE -->
        <div class="col s12 l3">

            <!-- CURRENT TURN -->
            <div class="card white z-depth-1" style="border-radius:18px;">
                <div class="card-content center-align">
                    <p class="grey-text">CURRENT TURN</p>
                    <h1 id="currentTurn" class="teal-text text-darken-2" style="margin:0; font-size:5rem;">
                        @(currentTurn?.Code ?? "—")
                    </h1>
                    <p class="grey-text">Now serving</p>
                </div>
            </div>

            <!-- NEXT TURNS -->
            <div class="card white z-depth-1" style="border-radius:18px;">
                <div class="card-content">
                    <h6 class="grey-text text-darken-3"><b>Next in line</b></h6>
                    <ul id="nextInLine" class="collection" style="border:none;">
                        @foreach (var ticket in tickets.Take(5))
                        {
                            <li class="collection-item">@ticket.Code</li>
                        }
                    </ul>
                </div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="col s12 l6">
            <div class="card white z-depth-1" style="border-radius:18px;">
                <div class="card-content">
                    <h6 class="grey-text text-darken-3"><b>Now Playing</b></h6>
                    <div class="video-container" style="border-radius:15px; overflow:hidden; margin-top:15px;">
                        <video id="waitingVideo"
                               src="/files/waitingroom.mp4"
                               autoplay
                               loop
                               muted
                               playsinline
                               style="width:100%; border-radius:15px;">
                            Tu navegador no soporta la reproducción de video.
                        </video>
                    </div>
                    <p class="center-align grey-text" style="margin-top:20px;">
                        While you wait, enjoy useful content and announcements.
                    </p>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- TOAST -->
<div id="toast" style="
    position: fixed;
    top: 20px;
    right: 20px;
    background: #26a69a;
    color: white;
    padding: 15px 20px;
    border-radius: 10px;
    display: none;
    z-index: 9999;
    font-weight: bold;">
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/turnHub")
        .withAutomaticReconnect()
        .build();

    const toast = document.getElementById("toast");

    connection.on("ReceiveTurn", (code) => {
        refreshTickets(code);
    });

    connection.start().then(() => {
        console.log("SignalR conectado - Sala de espera");
    });

    async function refreshTickets(incomingCode = null) {
        const res = await fetch('/Admin/GetTicketsPendings');
        const tickets = await res.json();

        document.getElementById("waitingCount").innerText = tickets.length;

        const list = document.getElementById("nextInLine");
        list.innerHTML = "";
        tickets.slice(0, 10).forEach(t => {
            list.innerHTML += `<li class="collection-item">${t.code}</li>`;
        });

        // Si el code que llegó NO está en pendientes, es el turno actual
        if (incomingCode) {
            const isPending = tickets.some(t => t.code === incomingCode);
            if (!isPending && incomingCode !== "NO_TICKETS") {
                // Sonido
                const ctx = new AudioContext();
                const oscillator = ctx.createOscillator();
                const gainNode = ctx.createGain();

                oscillator.connect(gainNode);
                gainNode.connect(ctx.destination);

                oscillator.type = "sine";
                oscillator.frequency.setValueAtTime(880, ctx.currentTime);
                oscillator.frequency.setValueAtTime(660, ctx.currentTime + 0.1);

                gainNode.gain.setValueAtTime(0.5, ctx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.5);

                oscillator.start(ctx.currentTime);
                oscillator.stop(ctx.currentTime + 0.5);

                // Lo que ya tenías
                document.getElementById("currentTurn").innerText = incomingCode;
                toast.innerText = Now serving: ${incomingCode};
                toast.style.display = "block";
                setTimeout(() => toast.style.display = "none", 3000);
            }
        }
    }

    refreshTickets();
</script>