@using NextInLine.Enums
@model IEnumerable<Ticket>
@{
ViewData["Title"] = "Sala de espera";

var tickets = Model
.Where(t => t.Status == TicketStatus.pending && t.CreatedAt.Date == DateTime.UtcNow.Date)
.OrderBy(t => t.CreatedAt)
.ToList();

var currentTurn = Model
.Where(t => t.Status == TicketStatus.open && t.CreatedAt.Date == DateTime.UtcNow.Date)
.OrderByDescending(t => t.CreatedAt)
.FirstOrDefault();
}

<div id="toast" class="nil-toast"></div>

@section Head {
<script>
    window.__initialWaiting = @tickets.Count;
</script>
}

<div class="nil-page">
    <div class="user-grid">

        <!-- ── Columna izquierda: turno actual + próximos ── -->
        <div>
            <div class="nil-card" style="margin-bottom:16px;">
                <div class="turn-display--user">
                    <div class="turn-label">Turno actual</div>
                    <div class="turn-code" id="currentTurn">@(currentTurn?.Code ?? "—")</div>
                    <div class="turn-sub">Atendiendo ahora</div>
                </div>
            </div>

            <div class="nil-card">
                <div class="nil-card__header">Próximos en fila</div>
                <ul class="queue-list" id="nextInLine">
                    @if (!tickets.Any())
                    {
                    <li class="queue-empty">Sin tickets en espera</li>
                    }
                    else
                    {
                    @foreach (var ticket in tickets.Take(10))
                    {
                    <li class="queue-item">
                        <span class="queue-code">@ticket.Code</span>
                        <span class="queue-time">@ticket.CreatedAt.ToString("HH:mm")</span>
                    </li>
                    }
                    }
                </ul>
            </div>
        </div>

        <!-- ── Columna derecha: video ── -->
        <div class="nil-card nil-video-card">
            <div class="nil-card__header">Sala de espera</div>
            <div class="nil-card__body">
                <video class="nil-video"
                       src="/files/waitingroom.mp4"
                       autoplay loop muted playsinline
                       style="width:100%;border-radius:10px;display:block;background:#0c1f3a;">
                    Tu navegador no soporta la reproducción de video.
                </video>
                <p class="video-caption">Mientras esperas, disfruta del contenido.</p>
            </div>
        </div>

    </div>
</div>


@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
<script>

    function hablar(code) {
        const mensaje = new SpeechSynthesisUtterance(`Turno ${code}, por favor pase a caja`);
        mensaje.lang = "es-ES";
        mensaje.rate = 0.9;

        const voces = speechSynthesis.getVoices();

        if (voces.length === 0) {
            // Las voces aún no cargaron, esperar el evento
            speechSynthesis.addEventListener("voiceschanged", () => {
                const voz = speechSynthesis.getVoices()
                        .find(v => v.lang.startsWith("es") && v.name.toLowerCase().includes("female"))
                    || speechSynthesis.getVoices().find(v => v.lang.startsWith("es"));
                if (voz) mensaje.voice = voz;
                speechSynthesis.speak(mensaje);
            }, { once: true });
        } else {
            const voz = voces.find(v => v.lang.startsWith("es") && v.name.toLowerCase().includes("female"))
                || voces.find(v => v.lang.startsWith("es"));
            if (voz) mensaje.voice = voz;
            speechSynthesis.speak(mensaje);
        }
    }

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/turnHub")
        .withAutomaticReconnect()
        .build();

    const toast        = document.getElementById("toast");
    const waitingCountEl = document.getElementById("waitingCount");

    // Desbloquear audio con primer click
    document.addEventListener("click", () => {
        const unlock = new Audio('/files/turnSoud.mp3');
        unlock.volume = 0;
        unlock.play().then(() => unlock.pause()).catch(() => {});
    }, { once: true });

    // Inicializar badge del layout con el conteo del servidor
    if (waitingCountEl && window.__initialWaiting !== undefined) {
        waitingCountEl.textContent = window.__initialWaiting;
    }

    // ── Sonidos ──
    function playSound(type) {
        try {
            const ctx  = new AudioContext();
            const osc  = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.connect(gain);
            gain.connect(ctx.destination);

            if (type === 'new') {
                osc.type = "sine";
                osc.frequency.setValueAtTime(1046, ctx.currentTime);
                osc.frequency.setValueAtTime(1318, ctx.currentTime + 0.12);
                gain.gain.setValueAtTime(0.35, ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.35);
                osc.start(ctx.currentTime);
                osc.stop(ctx.currentTime + 0.35);
            } else if (type === 'turn') {
                osc.type = "triangle";
                osc.frequency.setValueAtTime(880, ctx.currentTime);
                osc.frequency.setValueAtTime(660, ctx.currentTime + 0.15);
                osc.frequency.setValueAtTime(440, ctx.currentTime + 0.30);
                gain.gain.setValueAtTime(0.5, ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.55);
                osc.start(ctx.currentTime);
                osc.stop(ctx.currentTime + 0.55);
            }
        } catch (e) {}
    }

    // ── Actualizar lista y badge ──
    async function refreshTickets(incomingCode = null) {
        const res     = await fetch("/Admin/GetTicketsPendings");
        const tickets = await res.json();

        if (waitingCountEl) {
            const prev = parseInt(waitingCountEl.textContent) || 0;
            const next = tickets.length;

            if (next > prev) {
                playSound('new');
            }

            waitingCountEl.textContent = next;
        }

        const list = document.getElementById("nextInLine");
        if (!tickets.length) {
            list.innerHTML = `<li class="queue-empty">Sin tickets en espera</li>`;
        } else {
            list.innerHTML = tickets.slice(0, 10).map(t => {
                const d   = new Date(t.createdAt);
                const pad = n => String(n).padStart(2, "0");
                return `
                    <li class="queue-item">
                        <span class="queue-code">${t.code}</span>
                        <span class="queue-time">${pad(d.getHours())}:${pad(d.getMinutes())}</span>
                    </li>`;
            }).join("");
        }

        if (incomingCode && incomingCode !== "NO_TICKETS") {
            const isPending = tickets.some(t => t.code === incomingCode);
            if (!isPending) {
                const audio = new Audio('/files/turnSoud.mp3');
                audio.play().catch(err => console.error("Audio error:", err));

                hablar(incomingCode);

                document.getElementById("currentTurn").textContent = incomingCode;
                toast.textContent = `Turno llamado: ${incomingCode}`;
                toast.style.display = "block";
                setTimeout(() => toast.style.display = "none", 3000);
            }
        }
    }

    connection.on("ReceiveTurn", (code) => refreshTickets(code));
    connection.start().catch(err => console.error("SignalR error:", err));

    refreshTickets();
</script>
}