@model NextInLine.Models.User
@{
    ViewData["Title"] = "Obtén tu turno";
}

<div class="turn-page">

    <!-- ── Hero izquierdo ── -->
    <div class="turn-hero">
        <div class="turn-hero__eyebrow">Sistema de turnos digital</div>
        <h1 class="turn-hero__title">
            Tu turno,<br>
            sin <em>filas</em>,<br>
            sin esperas.
        </h1>
        <p class="turn-hero__desc">
            Regístrate en segundos y recibe tu turno digital.
            Te avisamos cuando sea tu momento, sin hacer cola física.
        </p>
        <div class="turn-hero__badges">
            <div class="turn-hero__badge">
                <span class="dot"></span>
                Sin papel
            </div>
            <div class="turn-hero__badge">
                <span class="dot"></span>
                Tiempo real
            </div>
            <div class="turn-hero__badge">
                <span class="dot"></span>
                Notificación sonora
            </div>
        </div>
    </div>

    <!-- ── Formulario ── -->
    <div class="form-card">
        <div class="form-card__header">
            <div class="form-card__title">Obtén tu turno</div>
            <p class="form-card__sub">Ingresa tus datos para unirte a la fila.</p>
        </div>
        <div class="form-card__body">

            @if (TempData["Success"] != null)
            {
                <div class="form-alert form-alert--success" id="alert-success">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="form-alert form-alert--error" id="alert-error">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    @TempData["Error"]
                </div>
            }

            <form asp-action="Save" asp-controller="User" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Rol"    value="user" />
                <input type="hidden" asp-for="Status" value="pending" />

                <div class="form-group">
                    <label class="form-label" asp-for="Name">Nombre completo</label>
                    <input class="form-input" asp-for="Name" placeholder="Ej. Juan Pérez" required />
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Email">Correo electrónico</label>
                    <input class="form-input" asp-for="Email" type="email" placeholder="correo@ejemplo.com" required />
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Document">Número de documento</label>
                    <input class="form-input" asp-for="Document" placeholder="CC / CE / Pasaporte" required />
                </div>

                <button type="submit" class="form-btn">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"/>
                        <polyline points="12 5 19 12 12 19"/>
                    </svg>
                    Obtener mi turno
                </button>
            </form>

        </div>
    </div>

</div>

@section Scripts {
<script>
    // Auto-dismiss alerts after 4 s
    setTimeout(() => {
        document.querySelectorAll('.form-alert').forEach(el => {
            el.style.transition = "opacity .4s";
            el.style.opacity = "0";
            setTimeout(() => el.remove(), 400);
        });
    }, 4000);
</script>
}
