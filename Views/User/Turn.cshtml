@model NextInLine.Models.User

<div class="container">
    <div class="row" style="min-height:100vh; display:flex; align-items:center;">

        <!-- LEFT SIDE -->
        <div class="col s12 m6 center-align">
            <h2 class="grey-text text-darken-4 thin">
                Welcome back to <br>
                <span class="teal-text text-darken-2"><i>Fila</i></span>
            </h2>

            <p class="flow-text grey-text text-darken-1">
                Manage queues, reduce waiting time, and deliver a better customer experience.
            </p>

            <p class="grey-text">
                Fast. Smart. Modern.
            </p>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col s12 l3">

            <!-- TAKE TURN -->
            <div class="card white z-depth-1" style="border-radius:18px;">
                <div class="card-content center-align">

                    <h5 class="grey-text text-darken-4">Need a Ticket?</h5>

                    <p class="grey-text">
                        Tap below to join the queue instantly.
                    </p>

                    @if (TempData["Success"] != null)
                    {
                        <div id="alert-success" class="card-panel green lighten-4 green-text text-darken-4 center">
                            @TempData["Success"]
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div id="alert-error" class="card-panel red lighten-4 red-text text-darken-4 center">
                            @TempData["Error"]
                        </div>
                    }

                    <!-- 📝 FORM -->
                    <form asp-action="Save" asp-controller="User" method="post">
                        <input type="hidden" asp-for="Rol" value="user" />
                        <input type="hidden" asp-for="Status" value="pending" />
                        <div class="input-field">
                            <i class="material-icons prefix">person</i>
                            <input asp-for="Name" required/>
                            <label asp-for="Name" class="active"></label>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix">email</i>
                            <input asp-for="Email" type="email" required/>
                            <label asp-for="Email" class="active"></label>
                        </div>

                        <div class="input-field">
                            <i class="material-icons prefix">account_box</i>
                            <input asp-for="Document" required/>
                            <label asp-for="Document" class="active"></label>
                        </div>

                        <button type="submit"
                                class="btn-large teal darken-1 waves-effect waves-light"
                                style="border-radius:30px; width:100%; margin-top:15px;">
                            Get My Turn
                        </button>
                    </form>

                </div>
            </div>

            <!-- HELP -->
            <div class="card white z-depth-1" style="border-radius:18px;">
                <div class="card-content center-align">

                    <i class="material-icons medium teal-text">support_agent</i>

                    <h6 class="grey-text text-darken-4"><b>Need Assistance?</b></h6>

                    <p class="grey-text">
                        Ask one of our advisors for help.
                    </p>

                </div>
            </div>

        </div>
    </div>
</div>

<script>
    setTimeout(() => {
        document.querySelectorAll('.card-panel').forEach(el => {
            el.style.transition = "opacity 0.5s";
            el.style.opacity = "0";

            setTimeout(() => el.remove(), 500);
        });
    }, 3000);
</script>